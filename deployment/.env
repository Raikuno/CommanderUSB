DATABASE_ROOT_PASSWORD=root
USBCOMMANDER_DATABASE=usbcommanderdb
MARIADB_USER=commander
MARIADB_PASSWORD=commander

DATABASE_URL=jdbc:mariadb://localhost:3306/usbcommanderdb
SERVER_PORT=8080
SOCKET_PORT=8081
